# ══════════════════════════════════════
# TruthForge Environment Variables
# Copy this file to .env and fill in values
# ══════════════════════════════════════

# ── Supabase Database ──
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_KEY=your_service_role_key_here

# ── Groq AI ──
GROQ_API_KEY=gsk_your_groq_api_key_here

# ── Bright Data ──
BRIGHT_DATA_API_KEY=your_bright_data_token_here
BRIGHT_DATA_SERP_URL=https://api.brightdata.com/request
BRIGHT_DATA_UNLOCKER_URL=https://api.brightdata.com/request
BRIGHT_DATA_ZONE_SERP=serp_api1
BRIGHT_DATA_ZONE_UNLOCKER=web_unlocker1

# ── Sentry Error Monitoring ──
SENTRY_DSN_BACKEND=https://your_key@sentry.io/your_project_id

# ── App Config ──
APP_ENV=development
APP_PORT=8000

# ── Redis (for Celery Workers) ──
REDIS_URL=redis://localhost:6379/0

# ── Slack Alerts (optional) ──
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/your/webhook/url